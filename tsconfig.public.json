{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "host/public",
    "outDir": "host/public/dist",
    "sourceMap": true,
    "declaration": false
  },
  "include": ["host/public/**/*.ts"],
  "exclude": ["host/public/dist", "node_modules", "host/public/**/*.test.ts"]
}
