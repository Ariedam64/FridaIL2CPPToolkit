{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "public",
    "outDir": "public/dist",
    "sourceMap": true,
    "declaration": false
  },
  "include": ["public/**/*.ts"],
  "exclude": ["public/dist", "node_modules"]
}
