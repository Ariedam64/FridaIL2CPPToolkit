{
  "compilerOptions": {
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist/backend",
    "rootDir": "./backend",
    "declaration": false
  },
  "include": ["backend/**/*.ts"]
}
